   nginx:
     image: "{{ sma.docker.images.nginx.image ~ ':' ~ sma.docker.images.nginx.version }}"
     restart: unless-stopped
     ports:
       # - "127.0.0.1:443:443" # Test IF
       # https://build.sma.de/documentation/services/nexus.html
       - 443:443 # WebUI, Maven, NPM, PyPi, ....
       - 9080:9080 # deprecated docker group
       - 5000:5000 # docker group
       - 9081:9081 # docker-public-auto
       - 9082:9082 # docker-private-auto
       - 9091:9091 # docker-public-auto-feature
       - 9092:9092 # docker-private-auto-feature
       - 9181:9181 # docker-public-manual
       - 9182:9182 # docker-private-manual
       - 9191:9191 # docker-public-manual-feature
       - 9192:9192 # docker-private-manual-feature

       # Nexus IQ-Server
       - 8080:8080
       - 8070:8070
       - 8071:8071

     depends_on:
       - nexus
##       - nexus_iq
     volumes:
       - "{{ smabot_dockcompose_prjdir }}/nginx.conf:/etc/nginx/nginx.conf:ro"
{##}
{% for cd in [ssl_certs.default_domain] + (ssl_certs_from_hvault_args.extra_domains | default([], True)) %}
       - "{{ ssl_certs.client.base_path ~ '/' ~ cd }}_cert.pem:/etc/ssl/certs/{{ cd }}_cert.pem:ro"
       - "{{ ssl_certs.client.base_path ~ '/' ~ cd }}_key.pem:/etc/ssl/certs/{{ cd }}_key.pem:ro"
{% endfor %}

