---

 services:
   postgres:
     container_name: nexus_db
     image: "{{ sma.docker.images.nexus_db.image ~ ':' ~ sma.docker.images.nexus_db.version }}"
     restart: unless-stopped
     volumes:
       - "{{ nexus_settings.local_dirs.data.db.path }}:/var/lib/postgresql/data"
     environment:
       POSTGRES_DB: nexus

       ## note: secrets are added dynamically during pipeline run
       POSTGRES_USER:
       POSTGRES_PASSWORD:

   {{ nexus_settings.docker.compose.services.nexus.name }}:
     container_name: nexus3
     image: >-
       {{ sma.docker.images.nexus.image ~ ':' ~ sma.docker.images.nexus.version }}

     ##
     ## note: as we externalize blob storage there should be no reason
     ##   anymore to "hard persist" nexus-data because other stuff
     ##   it contains like configuration and logs should not need
     ##   "hard persistence" (default docker volume should be enough)
     ##
     ##volumes:
     ##  - "{{ sma.disks.data.default.location }}/{{ ansible_role_name }}/nexus:/nexus-data"
     ##  - "{{ sma.disks.data.default.location }}/{{ ansible_role_name }}/nexus-repositories:/data/nexus-repositories"

     environment:
       NEXUS_DATASTORE_ENABLED: "true"
       NEXUS_DATASTORE_NEXUS_JDBCURL: "jdbc:postgresql://postgres:5432/nexus"

       NEXUS_DATASTORE_NEXUS_USERNAME:
       NEXUS_DATASTORE_NEXUS_PASSWORD:

     restart: unless-stopped
     depends_on:
       - postgres
       ##- nexus_iq
     ports:
       - "127.0.0.1:80:8081"

