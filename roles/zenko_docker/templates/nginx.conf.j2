events {
}

http {
    proxy_send_timeout        240;
    proxy_read_timeout        600;
    proxy_buffering           off;
    keepalive_timeout         10 10;
    tcp_nodelay               on;
    sendfile                  on;

    access_log off;

    client_max_body_size  80G;

    ssl_certificate /etc/ssl/certs/{{ ssl_certs.default_domain }}_cert.pem;
    ssl_certificate_key /etc/ssl/certs/{{ ssl_certs.default_domain }}_key.pem;

    server {
        listen 80;
        server_name _;
        return 301 https://$host$request_uri;
    }

