{#
##
## jinja template for nginx location proxy-pass block optimized (with
## AI input) for managing small metrics / check alive paths like for example
## k8s livecycle checks
##
## mainly intended to be inserted inside a location scope, but
## should also work more globally
##
#}
## ensure we dont use totally outdated http v1.0
proxy_http_version 1.1;

## allow efficient nginx based "upstream keepalive" management
proxy_set_header Connection "";

## disable nginx buffering completly
proxy_buffering on;
proxy_request_buffering on;

## reduce way to conservative default connection to
proxy_connect_timeout {{ _iter_rproxy_cfg_snippets.value.timeouts.proxy_connect | default('5s') }};

proxy_read_timeout    {{ _iter_rproxy_cfg_snippets.value.timeouts.proxy_read | default('5s') }};
proxy_send_timeout    {{ _iter_rproxy_cfg_snippets.value.timeouts.proxy_send | default('5s') }};
send_timeout          {{ _iter_rproxy_cfg_snippets.value.timeouts.send | default('5s') }};

## setting it to zero means no upper max size limit
client_max_body_size {{ _iter_rproxy_cfg_snippets.value.client_body_maxsize | default('32k') }};
