{#
##
## jinja template for nginx config, senseable generic defaults for
## any location proxy pass
##
#}
## senseable default proxy pass settings
proxy_set_header X-Real-IP          $remote_addr;
proxy_set_header X-Forwarded-For    $proxy_add_x_forwarded_for;
proxy_set_header X-Forwarded-Host   $host;
proxy_set_header X-Forwarded-Proto  $scheme;

##
## note: as aws-sigv4 works by signing complete request including
##   host (and port!) url part just forwarding ($host) does not
##   cut it here, it must be $http_host (host + original port) so
##   the s3 api endpoint accepts the request as valid
##
proxy_set_header Host               $http_host;
