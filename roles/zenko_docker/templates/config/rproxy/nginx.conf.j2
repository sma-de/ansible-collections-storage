{% if (_tmp_rproxy_cfg_settings._user_perm_handling.bcreate_restrict | default(False)) is truthy %}
  ## map authorization to just the Access Key ID (AKID) using named captures
  map $http_authorization $s3_akid {
    "~*Credential=(?<akid>[-_A-Z0-9]+)/" $akid;
    default  "";
  }

  ## ---------- allowlist for bucket creation ----------
  ## 1 = allowed to create buckets, 0 = denied
  map $s3_akid $may_create_bucket {
    ## owners/admins who can create buckets
{% for x in _tmp_rproxy_cfg_settings._user_perm_handling.bcreate_restrict.allow_users %}
    "{{ x.name }}"      1;
{% endfor %}

    ## all other users
    default  0;
  }

  ## flag if the request method is PUT
  map $request_method $is_put {
    default  0;
    PUT      1;
  }

  ## decide if we should deny CreateBucket (PUT to bucket root) for restricted users
  ## note: we only flip this flag in the bucket-root location, but it's fine to compute it globally
  map "$is_put:$may_create_bucket" $deny_create_bucket_map {
    "1:0"    1;   # PUT & user is not allowed
    default  0;   # everything else
  }

  # decide route: deny vs proxy
  map $deny_create_bucket_map $bucket_route {
    1        @deny_create_bucket_loc;
    default  @s3_proxy_loc;
  }

{% endif %}
